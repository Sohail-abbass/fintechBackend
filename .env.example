# API
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# JWT (generate strong secrets for production)
ACCESS_SECRET=change-me-access
REFRESH_SECRET=change-me-refresh

# PostgreSQL (match your Docker / compose: POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_DATABASE=fintech

# Set to false in production (use migrations instead)
DB_SYNCHRONIZE=true
DB_LOGGING=false
